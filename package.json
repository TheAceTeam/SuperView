{
  "name": "@seanxdo/superview",
  "version": "0.2.1",
  "description": "Coding-agent flight recorder — timeline dashboard with replayable agent-run drill-downs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAceTeam/SuperView.git"
  },
  "keywords": [
    "codex",
    "claude-code",
    "ai-agent",
    "observability",
    "llm-tracing",
    "agent-dashboard",
    "developer-tools"
  ],
  "bin": {
    "superview": "runtime-node/cli-start.js"
  },
  "files": [
    "runtime-node/",
    "core/",
    "storage/",
    "dist/ui/"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c orange,blue \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch runtime-node/dev-server.ts",
    "start": "node runtime-node/cli-start.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx runtime-node/cli-ingest.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "jsdom": "^27.3.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
